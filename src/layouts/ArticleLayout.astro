---
import '../styles/site.css';
import Masthead from '../components/Masthead.astro';
import SiteFooter from '../components/SiteFooter.astro';

const {
  title,
  authors,
  journal,
  volume,
  year,
  abstract,
  pdfUrl,
  ssrnUrl,
  localPdfUrl,
  keywords = [],
  awards = [],
  relatedTalks = [],
  publishDate,
  doi,
  backLink = { url: '/articles', text: 'Articles' }
} = Astro.props;

const fullAuthors = authors.join(', ');
const siteBase = Astro.site?.toString().replace(/\/$/, '') ?? 'https://andreatosato.com';
const currentUrl = `${siteBase}${Astro.url.pathname}`;

const eyebrow = backLink.url === '/essays' ? 'Essay' : 'Article';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | Andrea Tosato</title>
  <meta name="description" content={abstract ? abstract.substring(0, 160) : ''}>
  <meta name="author" content={fullAuthors}>
  <meta name="keywords" content={keywords.join(', ')}>

  <!-- Additional SEO Meta Tags -->
  <meta name="robots" content="index, follow">
  <meta name="language" content="English">
  <meta name="revisit-after" content="7 days">
  <meta name="category" content="Legal Research">
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="canonical" href={currentUrl}>

  <!-- Preload primary font weight to reduce FOUT -->
  <link rel="preload" as="font" type="font/woff2" href="/fonts/eb-garamond-400-normal-latin.woff2" crossorigin>

  <!-- Google Scholar Meta Tags (Highwire Press) -->
  <meta name="citation_title" content={title}>
  {authors.map(author => (
    <meta name="citation_author" content={author}>
  ))}
  <meta name="citation_publication_date" content={publishDate}>
  <meta name="citation_journal_title" content={journal}>
  {volume && <meta name="citation_volume" content={volume}>}
  {localPdfUrl ? <meta name="citation_pdf_url" content={`https://andreatosato.com${localPdfUrl}`}> : pdfUrl && <meta name="citation_pdf_url" content={pdfUrl}>}
  <meta name="citation_abstract_html_url" content={currentUrl}>
  <meta name="citation_abstract" content={abstract}>
  <meta name="citation_keywords" content={keywords.join('; ')}>
  <meta name="citation_language" content="en">
  {doi && <meta name="citation_doi" content={doi}>}
  {localPdfUrl && <link rel="alternate" type="application/pdf" href={`https://andreatosato.com${localPdfUrl}`}>}

  <!-- Dublin Core Metadata for Better Indexing -->
  <meta name="DC.title" content={title}>
  <meta name="DC.creator" content={fullAuthors}>
  <meta name="DC.subject" content={keywords.join(', ')}>
  <meta name="DC.description" content={abstract}>
  <meta name="DC.publisher" content={journal}>
  <meta name="DC.date" content={publishDate}>
  <meta name="DC.type" content="Text">
  <meta name="DC.format" content="text/html">
  <meta name="DC.language" content="en">

  <!-- Open Graph -->
  <meta property="og:title" content={title}>
  <meta property="og:description" content={abstract.substring(0, 200)}>
  <meta property="og:type" content="article">
  <meta property="og:url" content={currentUrl}>
  <meta property="og:site_name" content="Andrea Tosato">
  <meta property="article:author" content={fullAuthors}>
  <meta property="article:published_time" content={publishDate}>
  <meta property="article:section" content="Legal Research">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={abstract.substring(0, 200)}>

  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ScholarlyArticle",
    "headline": title,
    "author": authors.map(author => ({
      "@type": "Person",
      "name": author
    })),
    "datePublished": publishDate,
    "publication": journal,
    "abstract": abstract,
    "keywords": keywords.join(', '),
    "inLanguage": "en",
    "url": currentUrl,
    ...(localPdfUrl ? { "encoding": { "@type": "MediaObject", "contentUrl": `https://andreatosato.com${localPdfUrl}` } } : pdfUrl ? { "encoding": { "@type": "MediaObject", "contentUrl": pdfUrl } } : {})
  })} />
</head>
<body>
  <a class="skip" href="#main">Skip to content</a>
  <div class="page">
    <Masthead />
    <main id="main">
      <a class="back-link" href={backLink.url}>&larr; {backLink.text}</a>

      <article class="paper">
        <div class="section-label">{eyebrow}</div>
        <h1 class="paper-title">{title}</h1>
        <p class="authors">{fullAuthors}</p>
        <p class="citation">
          {volume && <span class="vol">{volume}&nbsp;</span>}<span class="venue">{journal}</span>&nbsp;<span class="year">({year})</span>
        </p>

        {awards.length > 0 && awards.map(award => (
          <p class="award-note">&mdash; {award}</p>
        ))}

        {abstract && (
          <>
            <h2 class="paper-section">Abstract</h2>
            <div class="abstract">
              <p>{abstract}</p>
            </div>
          </>
        )}

        {(localPdfUrl || pdfUrl || ssrnUrl) && (
          <div class="paper-actions">
            {localPdfUrl && (
              <a href={localPdfUrl} target="_blank" rel="noopener">Download PDF</a>
            )}
            {pdfUrl && (
              <>
                {localPdfUrl && <span class="dot">&middot;</span>}
                <a href={pdfUrl} target="_blank" rel="noopener">{localPdfUrl ? 'View Published Version' : 'Download PDF'}</a>
              </>
            )}
            {ssrnUrl && (
              <>
                {(localPdfUrl || pdfUrl) && <span class="dot">&middot;</span>}
                <a href={ssrnUrl} target="_blank" rel="noopener">View on SSRN</a>
              </>
            )}
          </div>
        )}

        {keywords.length > 0 && (
          <>
            <h2 class="paper-section">Keywords</h2>
            <ul class="keywords">
              {keywords.map(keyword => (
                <li>{keyword}</li>
              ))}
            </ul>
          </>
        )}

        {relatedTalks.length > 0 && (
          <div class="related-talks">
            <h3>Selected Presentations</h3>
            <ul>
              {relatedTalks.map(talk => (
                <li>{talk}</li>
              ))}
            </ul>
          </div>
        )}
      </article>
    </main>
    <SiteFooter />
  </div>
</body>
</html>
