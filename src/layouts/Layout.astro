---
const { 
  title, 
  description = "Andrea Tosato is Professor of Law at SMU Dedman School of Law. His research examines how private law, commercial law, and bankruptcy law govern modern intangible assets, including digital assets, stablecoins, and verified carbon credits."
} = Astro.props;
const currentPath = Astro.url.pathname;

// Enhanced meta description based on page
let pageDescription = description;
if (currentPath === '/' && !description) {
  pageDescription = "Andrea Tosato is Professor of Law at SMU Dedman School of Law. His research examines how private law, commercial law, and bankruptcy law govern modern intangible assets, including digital assets, stablecoins, and verified carbon credits.";
} else if (currentPath === '/about-me' && !description) {
  pageDescription = "Andrea Tosato is Professor of Law at SMU Dedman School of Law. His research examines the private law, commercial law, and bankruptcy treatment of modern intangible assets, including digital assets, stablecoins, and verified carbon credits.";
} else if (currentPath === '/articles' && !description) {
  pageDescription = "Law review articles by Andrea Tosato on private law, commercial law, bankruptcy, secured transactions, digital assets, stablecoins, and verified carbon credits.";
}

// Schema.org structured data
const schemaData = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Andrea Tosato",
  "alternateName": "Prof. Andrea Tosato",
  "givenName": "Andrea",
  "familyName": "Tosato",
  "jobTitle": "Professor of Law",
  "description": "Private law and commercial law scholar whose research focuses on the legal treatment of modern intangible assets, including digital assets, stablecoins, and verified carbon credits",
  "knowsAbout": [
    "Private Law",
    "Commercial Law",
    "Bankruptcy Law",
    "Property Law",
    "Secured Transactions",
    "Intangible Assets",
    "Digital Assets Law",
    "UCC Article 12",
    "Stablecoins",
    "Controllable Electronic Records",
    "Verified Carbon Credits"
  ],
  "affiliation": {
    "@type": "Organization",
    "name": "SMU Dedman School of Law",
    "url": "https://www.smu.edu/law"
  },
  "alumniOf": [
    {
      "@type": "Organization",
      "name": "University of Cambridge"
    },
    {
      "@type": "Organization",
      "name": "University of Pavia"
    }
  ],
  "url": "https://www.andreatosato.com",
  "sameAs": [
    "https://www.smu.edu/law/faculty/profiles/tosato-andrea",
    "https://www.linkedin.com/in/andrea-tosato-5a862067/",
    "https://x.com/Andrea_Tosato",
    "https://papers.ssrn.com/sol3/cf_dev/AbsByAuth.cfm?per_id=1851659",
    "https://scholar.google.com/citations?user=gvFpxc4AAAAJ",
    "https://orcid.org/0000-0002-2607-2702"
  ],
  "worksFor": {
    "@type": "EducationalOrganization",
    "name": "SMU Dedman School of Law"
  },
  "award": [
    "Grant Gilmore Award - American College of Commercial Finance Lawyers",
    "Shook Hardy Bacon Research Award",
    "American Law Institute Membership"
  ],
  "hasOccupation": [
    {
      "@type": "Role",
      "roleName": "Associate Research Director",
      "memberOf": {
        "@type": "Organization",
        "name": "Permanent Editorial Board for the Uniform Commercial Code"
      }
    },
    {
      "@type": "Role",
      "roleName": "Reporter",
      "memberOf": {
        "@type": "Organization",
        "name": "Uniform Law Commission Study Committee on Verified Carbon Credits"
      }
    },
    {
      "@type": "Role",
      "roleName": "Member",
      "memberOf": {
        "@type": "Organization",
        "name": "UNIDROIT Drafting Committee for the Working Group on Verified Carbon Credits"
      }
    }
  ]
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title ? `${title} | Andrea Tosato` : 'Andrea Tosato | Professor of Law | Private Law and Commercial Law'}</title>
  <meta name="description" content={pageDescription}>
  
  <!-- Additional SEO meta tags -->
  <meta name="keywords" content="Andrea Tosato, private law, commercial law, bankruptcy law, property law, secured transactions, intangible assets, digital assets law, UCC Article 12, stablecoins, controllable electronic records, verified carbon credits">
  <meta name="author" content="Andrea Tosato">
  <link rel="icon" href="/favicon.ico" sizes="32x32">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="canonical" href={`https://www.andreatosato.com${currentPath}`}>
  
  <!-- Open Graph meta tags for social media -->
  <meta property="og:title" content={title ? `${title} | Andrea Tosato` : 'Andrea Tosato | Professor of Law | Private Law and Commercial Law'}>
  <meta property="og:description" content={pageDescription}>
  <meta property="og:url" content={`https://www.andreatosato.com${currentPath}`}>
  <meta property="og:type" content="profile">
  <meta property="og:image" content="https://www.andreatosato.com/profile.jpg">
  
  <!-- Twitter Card meta tags -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:site" content="@Andrea_Tosato">
  <meta name="twitter:creator" content="@Andrea_Tosato">
  <meta name="twitter:title" content={title ? `${title} | Andrea Tosato` : 'Andrea Tosato | Professor of Law | Private Law and Commercial Law'}>
  <meta name="twitter:description" content={pageDescription}>
  <meta name="twitter:image" content="https://www.andreatosato.com/profile.jpg">
  
  <!-- Schema.org structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
      line-height: 1.7;
      color: #000;
      background: #fff;
      font-size: 17px;
    }
    /* Navigation */
    nav {
      border-bottom: 1px solid #000;
      padding: 1.2rem 0;
      background: #fff;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
      display: flex;
      align-items: center;
      gap: 3rem;
    }
    .nav-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-right {
      flex: 1;
    }
    .nav-name {
      font-size: 1.8rem;
      font-weight: 300;
      letter-spacing: -0.02em;
      white-space: nowrap;
    }
    .nav-name a {
      color: #000;
      text-decoration: none;
    }

    /* Hamburger toggle button */
    .nav-toggle {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 5px;
    }
    .nav-toggle span {
      width: 25px;
      height: 2px;
      background-color: #000;
      transition: 0.3s;
    }

    /* Primary nav row */
    .nav-primary {
      display: flex;
      gap: 3rem;
      list-style: none;
      align-items: center;
      justify-content: center;
    }
    .nav-primary a {
      color: #000;
      text-decoration: none;
      font-size: 1.15rem;
      font-weight: 400;
      transition: opacity 0.2s;
    }
    .nav-primary a:hover,
    .nav-primary a.active {
      opacity: 0.5;
    }

    /* Secondary nav row */
    .nav-secondary {
      display: flex;
      justify-content: center;
      gap: 2rem;
      list-style: none;
      margin-top: 0.5rem;
    }
    .nav-secondary a {
      color: #000;
      text-decoration: none;
      font-size: 1rem;
      font-weight: 400;
      transition: opacity 0.2s;
    }
    .nav-secondary a:hover,
    .nav-secondary a.active {
      opacity: 0.5;
    }
    .nav-separator {
      color: #ddd;
      user-select: none;
    }
    /* Main Content */
    main {
      min-height: 60vh;
    }
    /* Footer */
    footer {
      border-top: 1px solid #000;
      padding: 2rem;
      text-align: center;
      margin-top: 4rem;
      font-size: 0.9rem;
      color: #666;
    }
    .footer-links {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      flex-wrap: wrap;
      margin-bottom: 0.75rem;
    }
    .footer-links a {
      color: #999;
      text-decoration: none;
      font-size: 0.8rem;
      letter-spacing: 0.03em;
      transition: color 0.2s;
    }
    .footer-links a:hover {
      color: #000;
    }
    /* Mobile Navigation */
    @media (max-width: 900px) {
      .nav-container {
        position: relative;
      }

      .nav-toggle {
        display: flex;
      }

      .nav-right {
        display: none;
      }

      .nav-container {
        flex-wrap: wrap;
      }

      .nav-separator {
        display: none;
      }

      /* Mobile menu */
      .nav-mobile {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #fff;
        margin-top: 1.5rem;
        border: 1px solid #000;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
      }

      .nav-mobile.active {
        display: block;
      }

      .nav-group-label {
        display: block;
        padding: 0.75rem 1.5rem 0.4rem;
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #999;
        border-top: 1px solid #eee;
        cursor: pointer;
        user-select: none;
      }

      .nav-group-label:first-child {
        border-top: none;
      }

      .nav-group-label::after {
        content: ' +';
        float: right;
        font-size: 0.85rem;
        color: #ccc;
      }

      .nav-group-label.expanded::after {
        content: ' \2013';
      }

      .nav-group {
        list-style: none;
        display: none;
      }

      .nav-group.expanded {
        display: block;
      }

      .nav-group li {
        border-bottom: 1px solid #f0f0f0;
      }

      .nav-group li:last-child {
        border-bottom: none;
      }

      .nav-group a {
        display: block;
        padding: 0.85rem 1.5rem 0.85rem 2.2rem;
        color: #000;
        text-decoration: none;
        font-size: 0.95rem;
        transition: opacity 0.2s;
      }

      .nav-group a:hover,
      .nav-group a.active {
        opacity: 0.5;
      }
    }

    /* Hide mobile menu on desktop */
    @media (min-width: 901px) {
      .nav-mobile {
        display: none !important;
      }
    }
  </style>
</head>
<body>
  <nav>
    <div class="nav-container">
      <div class="nav-name">
        <a href="/">Andrea Tosato</a>
      </div>
      <button class="nav-toggle" aria-label="Toggle navigation">
        <span></span>
        <span></span>
        <span></span>
      </button>
      <div class="nav-right">
        <ul class="nav-primary">
          <li><a href="/research" class={currentPath.startsWith('/research') ? 'active' : ''}>Research</a></li>
          <li><a href="/articles" class={currentPath === '/articles' || currentPath.startsWith('/articles/') ? 'active' : ''}>Articles</a></li>
          <li><a href="/essays" class={currentPath === '/essays' || currentPath.startsWith('/essays/') ? 'active' : ''}>Essays</a></li>
          <li><a href="/books" class={currentPath === '/books' ? 'active' : ''}>Books</a></li>
        </ul>
        <ul class="nav-secondary">
        <li><a href="/about-me" class={currentPath === '/about-me' ? 'active' : ''}>About Me</a></li>
        <li><span class="nav-separator">&middot;</span></li>
        <li><a href="/news" class={currentPath === '/news' ? 'active' : ''}>News</a></li>
        <li><span class="nav-separator">&middot;</span></li>
        <li><a href="/teaching" class={currentPath === '/teaching' ? 'active' : ''}>Teaching</a></li>
        <li><span class="nav-separator">&middot;</span></li>
        <li><a href="/law-reform" class={currentPath === '/law-reform' ? 'active' : ''}>Law Reform</a></li>
        <li><span class="nav-separator">&middot;</span></li>
        <li><a href="/invited-talks" class={currentPath === '/invited-talks' ? 'active' : ''}>Invited Talks</a></li>
        <li><span class="nav-separator">&middot;</span></li>
        <li><a href="/media" class={currentPath === '/media' ? 'active' : ''}>Media</a></li>
      </ul>
      </div>

      <!-- Mobile navigation -->
      <div class="nav-mobile">
        <span class="nav-group-label expanded">Scholarship</span>
        <ul class="nav-group expanded">
          <li><a href="/research" class={currentPath.startsWith('/research') ? 'active' : ''}>Research</a></li>
          <li><a href="/articles" class={currentPath === '/articles' || currentPath.startsWith('/articles/') ? 'active' : ''}>Articles</a></li>
          <li><a href="/essays" class={currentPath === '/essays' || currentPath.startsWith('/essays/') ? 'active' : ''}>Essays</a></li>
          <li><a href="/books" class={currentPath === '/books' ? 'active' : ''}>Books</a></li>
        </ul>
        <span class="nav-group-label">Professional</span>
        <ul class="nav-group">
          <li><a href="/about-me" class={currentPath === '/about-me' ? 'active' : ''}>About Me</a></li>
          <li><a href="/news" class={currentPath === '/news' ? 'active' : ''}>News</a></li>
          <li><a href="/teaching" class={currentPath === '/teaching' ? 'active' : ''}>Teaching</a></li>
          <li><a href="/law-reform" class={currentPath === '/law-reform' ? 'active' : ''}>Law Reform</a></li>
          <li><a href="/invited-talks" class={currentPath === '/invited-talks' ? 'active' : ''}>Invited Talks</a></li>
          <li><a href="/media" class={currentPath === '/media' ? 'active' : ''}>Media</a></li>
        </ul>
      </div>
    </div>
  </nav>
  <main>
    <slot />
  </main>
  <footer>
    <div class="footer-links">
      <a href="https://papers.ssrn.com/sol3/cf_dev/AbsByAuth.cfm?per_id=1851659" target="_blank" rel="noopener">SSRN</a>
      <a href="https://www.smu.edu/law/faculty/profiles/tosato-andrea" target="_blank" rel="noopener">SMU Profile</a>
      <a href="https://www.linkedin.com/in/andrea-tosato-5a862067/" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://scholar.google.com/citations?user=gvFpxc4AAAAJ" target="_blank" rel="noopener">Google Scholar</a>
      <a href="https://orcid.org/0000-0002-2607-2702" target="_blank" rel="noopener">ORCID</a>
    </div>
    <p>© {new Date().getFullYear()} Andrea Tosato. All rights reserved.</p>
  </footer>
  
  <script>
    const navToggle = document.querySelector('.nav-toggle');
    const navMobile = document.querySelector('.nav-mobile');

    if (navToggle && navMobile) {
      navToggle.addEventListener('click', function() {
        navMobile.classList.toggle('active');
      });

      // Group expand/collapse
      const groupLabels = navMobile.querySelectorAll('.nav-group-label');
      groupLabels.forEach(label => {
        label.addEventListener('click', function() {
          this.classList.toggle('expanded');
          const group = this.nextElementSibling;
          if (group) group.classList.toggle('expanded');
        });
      });

      // Close menu when clicking a link
      const links = navMobile.querySelectorAll('a');
      links.forEach(link => {
        link.addEventListener('click', function() {
          navMobile.classList.remove('active');
        });
      });
    }
  </script>
</body>
</html>
