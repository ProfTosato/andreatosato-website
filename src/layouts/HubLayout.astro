---
import Layout from './Layout.astro';

const {
  title,
  description,
  relatedArticles = [],
  relatedEssays = []
} = Astro.props;

const currentUrl = `https://andreatosato.com${Astro.url.pathname}`;

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": currentUrl,
  "author": {
    "@type": "Person",
    "name": "Andrea Tosato",
    "url": "https://andreatosato.com"
  }
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />

  <a class="back-link" href="/research">&larr; Research</a>

  <div class="page-header">
    <div class="section-label">Research</div>
    <h1 class="page-title">{title}</h1>
  </div>

  <div class="hub-prose">
    <slot />
  </div>

  {(relatedArticles.length > 0 || relatedEssays.length > 0) && (
    <div class="related-scholarship">
      <h2>Related Scholarship</h2>

      {relatedArticles.length > 0 && (
        <>
          <div class="related-subhead">Articles</div>
          <ul class="related-list">
            {relatedArticles.map(article => (
              <li><a href={article.url}>{article.title}</a></li>
            ))}
          </ul>
        </>
      )}

      {relatedEssays.length > 0 && (
        <>
          <div class="related-subhead">Essays</div>
          <ul class="related-list">
            {relatedEssays.map(essay => (
              <li><a href={essay.url}>{essay.title}</a></li>
            ))}
          </ul>
        </>
      )}
    </div>
  )}
</Layout>
