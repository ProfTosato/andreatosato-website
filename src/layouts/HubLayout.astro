---
import Layout from './Layout.astro';

const {
  title,
  description,
  relatedArticles = [],
  relatedEssays = []
} = Astro.props;

const currentUrl = `https://www.andreatosato.com${Astro.url.pathname}`;

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": currentUrl,
  "author": {
    "@type": "Person",
    "name": "Andrea Tosato",
    "url": "https://www.andreatosato.com"
  }
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />

  <style>
    .hub-content {
      max-width: 850px;
      margin: 0 auto;
      padding: 2.5rem 2rem 3rem 2rem;
    }

    .hub-back {
      display: inline-block;
      color: #000;
      text-decoration: none;
      font-size: 1rem;
      margin-bottom: 2rem;
      transition: opacity 0.2s;
    }

    .hub-back:hover {
      opacity: 0.5;
    }

    .hub-content h1 {
      font-size: 2.5rem;
      font-weight: 300;
      line-height: 1.3;
      margin-bottom: 2rem;
      letter-spacing: -0.02em;
      color: #000;
    }

    .hub-prose {
      font-size: 1.05rem;
      line-height: 1.9;
      color: #000;
      text-align: justify;
      margin-bottom: 3rem;
    }

    .hub-prose :global(p) {
      margin-bottom: 1.2rem;
    }

    .related-scholarship {
      border-top: 1px solid #e0e0e0;
      padding-top: 2rem;
      margin-top: 2rem;
    }

    .related-scholarship h2 {
      font-size: 1rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
      color: #000;
    }

    .related-subhead {
      font-size: 0.9rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #666;
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
    }

    .related-list {
      list-style: none;
      padding: 0;
    }

    .related-list li {
      padding: 0.5rem 0;
      border-bottom: 1px solid #f0f0f0;
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .related-list li:last-child {
      border-bottom: none;
    }

    .related-list a {
      color: #000;
      text-decoration: none;
      transition: opacity 0.2s;
    }

    .related-list a:hover {
      opacity: 0.5;
      text-decoration: underline;
    }

    .hub-prose :global(h2) {
      font-size: 1.35rem;
      font-weight: 600;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
      letter-spacing: -0.01em;
      color: #000;
    }

    .hub-prose :global(h2:first-child) {
      margin-top: 0;
    }

    .hub-prose :global(strong) {
      font-weight: 600;
    }

    .hub-prose :global(em) {
      font-style: italic;
    }

    .hub-prose :global(sup) {
      font-size: 0.7em;
      line-height: 0;
      position: relative;
      vertical-align: baseline;
      top: -0.5em;
    }

    .hub-prose :global(sup a) {
      color: #000;
      text-decoration: none;
      border-bottom: 1px solid #ccc;
      padding: 0 1px;
      transition: opacity 0.2s;
    }

    .hub-prose :global(sup a:hover) {
      opacity: 0.5;
    }

    .hub-prose :global(blockquote) {
      margin: 1.5rem 0;
      padding: 1rem 1.5rem;
      border-left: 3px solid #e0e0e0;
      font-style: italic;
      color: #333;
    }

    .hub-prose :global(.endnotes) {
      border-top: 1px solid #e0e0e0;
      margin-top: 2.5rem;
      padding-top: 1.5rem;
    }

    .hub-prose :global(.endnotes h2) {
      font-size: 1rem;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 1rem;
      margin-top: 0;
    }

    .hub-prose :global(.endnotes ol) {
      padding-left: 2rem;
      margin: 0;
    }

    .hub-prose :global(.endnotes li) {
      font-size: 0.85rem;
      line-height: 1.6;
      color: #444;
      margin-bottom: 0.4rem;
    }

    .hub-prose :global(.endnotes a) {
      color: #000;
      text-decoration: none;
      border-bottom: 1px solid #ccc;
      transition: opacity 0.2s;
    }

    .hub-prose :global(.endnotes a:hover) {
      opacity: 0.5;
    }

    @media (max-width: 768px) {
      .hub-content {
        padding: 2rem 1.5rem;
      }

      .hub-content h1 {
        font-size: 2rem;
      }
    }
  </style>

  <div class="hub-content">
    <a href="/research" class="hub-back">&larr; Back to Research</a>

    <h1>{title}</h1>

    <div class="hub-prose">
      <slot />
    </div>

    {(relatedArticles.length > 0 || relatedEssays.length > 0) && (
      <div class="related-scholarship">
        <h2>Related Scholarship</h2>

        {relatedArticles.length > 0 && (
          <div>
            <div class="related-subhead">Articles</div>
            <ul class="related-list">
              {relatedArticles.map(article => (
                <li><a href={article.url}>{article.title}</a></li>
              ))}
            </ul>
          </div>
        )}

        {relatedEssays.length > 0 && (
          <div>
            <div class="related-subhead">Essays</div>
            <ul class="related-list">
              {relatedEssays.map(essay => (
                <li><a href={essay.url}>{essay.title}</a></li>
              ))}
            </ul>
          </div>
        )}
      </div>
    )}
  </div>
</Layout>
