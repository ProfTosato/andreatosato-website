  },
  {
    date: "2026-02-05",
    title: "Bankrupt Crypto Organizations wins SEALS Submission of the Year Award",
    description: "The co-authored article \"Bankrupt Crypto Organizations,\" forthcoming in the North Carolina Law Review, has been selected as the 2026 Submission of the Year by the Southeastern Association of Law Schools. The award will be conferred at the SEALS Annual Conference on 29 July 2026.",
    url: "/articles/bankrupt-crypto-organizations",
    external: false,
    category: "Awards & Recognition"
  },
  {
    date: "2025-10-01",
    title: "Professor Andrea Tosato elected to the American Law Institute",
    description: "Andrea Tosato has been elected to membership in the American Law Institute, one of the highest honours in the American legal profession. The ALI is responsible for producing scholarly work to clarify, modernise, and improve the law, including the Restatements of the Law and Model Codes such as the Uniform Commercial Code.",
    url: "https://www.smu.edu/law/news-events/2025/professor-andrea-tosato-elected-to-ali-membership",
    external: true,
    category: "Awards & Recognition"
  },
  {
    date: "2025-07-01",
    title: "UCC Article 12 enacted in 30+ states",
    description: "The 2022 UCC amendments, including Article 12 on controllable electronic records, have now been enacted in over 30 states. Professor Tosato continues his work as Associate Research Director of the Permanent Editorial Board for the UCC, supporting implementation across all U.S. jurisdictions.",
    url: "https://www.uniformlaws.org/committees/community-home?CommunityKey=1457c422-ddb7-40b0-8c76-39a1991651ac",
    external: true,
    category: "Law Reform"
  },
  {
    date: "2025-06-01",
    title: "Featured on Block & Order Podcast: Bankrupt Crypto Organizations",
    description: "Professor Tosato discusses his forthcoming North Carolina Law Review article examining how bankruptcy law principles apply when a debtor holds or operates with digital assets. The conversation explores the treatment of cryptocurrency exchanges and DeFi platforms in insolvency proceedings.",
    url: "/articles/bankrupt-crypto-organizations",
    external: false,
    category: "Media & Podcasts"
  },
  {
    date: "2025-04-16",
    title: "Speaking at American Bar Association Business Law Section Annual Meeting",
    description: "Professor Tosato presented on the intersection of UCC Article 12 and bankruptcy law at the ABA Business Law Section Annual Meeting. The presentation addressed emerging issues in the treatment of digital assets in insolvency proceedings.",
    url: "/articles/bankrupt-crypto-organizations",
    external: false,
    category: "Speaking Engagements"
  },
  {
    date: "2025-03-18",
    title: "Digital Assets and the Property Question featured in Oxford Business Law Blog",
    description: "Professor Tosato's forthcoming Florida Law Review article with Christopher Odinet is featured in the Oxford Business Law Blog, discussing fundamental questions about property rights in digital assets.",
    url: "/articles/digital-assets-property-question",
    external: false,
    category: "Publications"
  },
  {
    date: "2024-05-16",
    title: "Debt Tokens article featured in The ALI Adviser",
    description: "The ALI Adviser features Professor Tosato's University of Pennsylvania Law Review article on debt tokens, examining how UCC Article 12 applies to blockchain-based debt instruments.",
    url: "/articles/debt-tokens",
    external: false,
    category: "Publications"
  },
  {
    date: "2023-10-04",
    title: "UNIDROIT Principles on Digital Assets and Private Law published",
    description: "The UNIDROIT Principles on Digital Assets and Private Law, for which Professor Tosato served on the Drafting Committee, were officially published. This international instrument provides a framework for jurisdictions worldwide to develop coherent legal approaches to digital asset transactions.",
    url: "https://www.unidroit.org/work-in-progress/digital-assets-and-private-law/",
    external: true,
    category: "Law Reform"
  },
  {
    date: "2023-05-10",
    title: "The Private Law of Stablecoins wins Grant Gilmore Award",
    description: "Professor Tosato's article with Kara Bruce and Christopher Odinet published in the Arizona State Law Journal receives the Grant Gilmore Award from the American College of Commercial Finance Lawyers in recognition of superior writing in the field of commercial finance law.",
    url: "/articles/private-law-stablecoins",
    external: false,
    category: "Awards & Recognition"
  },
  {
    date: "2023-04-07",
    title: "Featured in Barron's: Crypto's future and commercial law",
    description: "Analysis of how the UCC Article 12 amendments are shaping the legal framework for cryptocurrency transactions in the United States. The article examines the implications of controllable electronic records for the future of digital asset regulation.",
    url: "https://www.barrons.com/articles/crypto-commercial-laws-definition-of-money-5fbd8fe4",
    external: true,
    category: "Media & Press"
  },
  {
    date: "2022-07-21",
    title: "2022 UCC Amendments and Article 12 approved",
    description: "The Uniform Law Commission and American Law Institute approve the 2022 amendments to the Uniform Commercial Code, including new Article 12 on controllable electronic records. Professor Tosato served as a key contributor to the drafting committee.",
    url: "https://www.uniformlaws.org/committees/community-home?CommunityKey=e104aaa8-c10f-45a7-a34a-0423c2106778",
    external: true,
    category: "Law Reform"
  }
];

const months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
function humanDate(iso: string) {
  const [y, m, d] = iso.split('-').map(Number);
  return `${d} ${months[m - 1]} ${y}`;
}

const newsByYear = allNews.reduce((acc, news) => {
  const year = Number(news.date.slice(0, 4));
  if (!acc[year]) acc[year] = [];
  acc[year].push(news);
  return acc;
}, {} as Record<number, typeof allNews>);

for (const year of Object.keys(newsByYear)) {
  newsByYear[Number(year)].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
}

const years = Object.keys(newsByYear).map(Number).sort((a, b) => b - a);
---

<Layout
  title="News"
  description="Updates on publications, awards, invited talks, media appearances, and law reform work across private law, commercial law, bankruptcy, and modern intangible assets."
>
  <div class="page-header">
    <div class="section-label">News</div>
    <h1 class="page-title">News</h1>
    <p class="page-lede">Updates on publications, speaking engagements, awards and other developments.</p>
  </div>

  {years.map(year => (
    <section class="news-year">
      <h2 class="year-heading tabular">{year}</h2>
      {newsByYear[year].map(news => (
        <article class="news-entry">
          <time class="news-date tabular" datetime={news.date}>{humanDate(news.date)}</time>
          <div class="news-body">
            <div class="category">{news.category}</div>
            <h3>
              <a href={news.url} target={news.external ? "_blank" : undefined} rel={news.external ? "noopener" : undefined}>{news.title}</a>
            </h3>
            <p>{news.description}</p>
          </div>
        </article>
      ))}
    </section>
  ))}
</Layout>
