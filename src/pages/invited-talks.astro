---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Invited Talks">
  <style>
    .content {
      max-width: 850px;
      margin: 0 auto;
      padding: 2.5rem 2rem;
    }

    h1 {
      font-size: 2.5rem;
      font-weight: 300;
      margin-bottom: 2.5rem;
      letter-spacing: -0.02em;
      color: #000;
    }

    h2 {
      font-size: 1.3rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-top: 2.5rem;
      margin-bottom: 1.5rem;
      color: #000;
    }

    h2:first-of-type {
      margin-top: 0;
    }

    .talk-item {
      margin-bottom: 1.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid #f0f0f0;
      line-height: 1.7;
    }

    .talk-item:last-child {
      border-bottom: none;
    }

    .talk-item a {
      color: #000;
      text-decoration: none;
      transition: opacity 0.2s;
    }

    .talk-item a:hover {
      opacity: 0.5;
      text-decoration: underline;
    }

    .article-ref {
      display: inline-block;
      font-size: 0.85rem;
      color: #666;
      margin-left: 0.5rem;
    }

    .article-ref:hover {
      color: #000;
    }

    @media (max-width: 768px) {
      .content {
        padding: 2rem 1.5rem;
      }

      h1 {
        font-size: 2rem;
      }

      h2 {
        font-size: 1.1rem;
      }
    }
  </style>

  <div class="content">
    <h1>Invited Talks</h1>

    <h2>Selected Presentations</h2>

    <div class="talk-item">
      The Federal Reserve Bank of New York, New York City. Crypto and the Property Question (2025) <a href="/articles/digital-assets-property-question" class="article-ref">→ Digital Assets and the Property Question</a>
    </div>

    <div class="talk-item">
      Pacific Law Foundation, Arlington. "Bundle of Sticks" Has Become Inadequate for Modern Digital Assets and Should Be Refined (2025) <a href="/articles/digital-assets-property-question" class="article-ref">→ Digital Assets and the Property Question</a>
    </div>

    <div class="talk-item">
      UNCITRAL Colloquium: Navigating the new era of digital finance, New York City. Verified Carbon Credits as Collateral in Secured Transactions (2025)
    </div>

    <div class="talk-item">
      VII Conference on International Coordination of Secured Transactions Reform. Verified Carbon Credits: Private Law Regime and Use as Collateral (2024)
    </div>

    <div class="talk-item">
      Practicing Law Institute, San Francisco. NFTs in Commercial Transactions (2024) <a href="/essays/nfts-structured-finance" class="article-ref">→ The Intersection of NFTs and Structured Finance</a>
    </div>

    <div class="talk-item">
      Harvard University, Harvard-Wharton Insolvency and Restructuring Conference, Boston. DAOs in Financial Distress (2024) <a href="/articles/bankrupt-crypto-organizations" class="article-ref">→ Bankrupt Crypto Organizations</a>
    </div>

    <div class="talk-item">
      University of Pennsylvania, Regulation & Governance Conference, Philadelphia. Debt Tokens (2024) <a href="/articles/debt-tokens" class="article-ref">→ Debt Tokens</a>
    </div>

    <div class="talk-item">
      BYU/UChicago, Winter Bankruptcy Conference, Park City. Debt Tokens (2024) <a href="/articles/debt-tokens" class="article-ref">→ Debt Tokens</a>
    </div>

    <div class="talk-item">
      Office of the Comptroller of The Currency, Washington DC. Tokenization (2024)
    </div>

    <div class="talk-item">
      University of Chicago, Chicago. Digital Assets & the 2022 UCC Amendments (2024)
    </div>

    <div class="talk-item">
      Association of American Law Schools, Washington DC. Debt Tokens (2024) <a href="/articles/debt-tokens" class="article-ref">→ Debt Tokens</a>
    </div>

    <div class="talk-item">
      UNIDROIT, Rome. The DAPL Principles and the Transfer of Digital Assets (2023)
    </div>

    <div class="talk-item">
      Texas A&M Law School, Fort Worth. UCC Article 12: It is All About Control! (2023)
    </div>

    <div class="talk-item">
      Association of American Law Schools, San Diego. Digital Assets, Virtual Currencies, & UCC Reform (2023)
    </div>

    <div class="talk-item">
      The Federal Reserve Bank of New York, New York. The Private Law of Stablecoins (2022) <a href="/articles/private-law-stablecoins" class="article-ref">→ The Private Law of Stablecoins</a>
    </div>

    <div class="talk-item">
      Baruch College, New York City. The emerging private law framework for digital assets (2022)
    </div>

    <div class="talk-item">
      UNIDROIT, Rome. Enforcement and Digital Assets: Rights of Secured Creditors (2022)
    </div>

    <div class="talk-item">
      Brooklyn Law School, New York City. Commercial Law Harmonization: Past as Prologue (2022)
    </div>

    <div class="talk-item">
      American Bar Association, Business Law Section 2022 Spring Meeting, Atlanta. College of Commercial Finance Lawyers. UCC and Emerging Technologies (2022)
    </div>

    <div class="talk-item">
      American College of Commercial Finance Lawyers. UCC and Emerging Technologies (2021)
    </div>

    <div class="talk-item">
      University of Wien. Vienna. ULC/ALI Project on Digital Assets: Comparative observations (2021)
    </div>

    <div class="talk-item">
      UNIDROIT. Rome. Model Law on Warehouse Receipts: Contractual Issues (2020)
    </div>

    <div class="talk-item">
      UNIDROIT. Rome. Distributed Ledger Technology and international sales of commodities (2019)
    </div>
  </div>
</Layout>
