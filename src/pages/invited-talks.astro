---
import Layout from '../layouts/Layout.astro';

type Talk = { year: number; venue: string; title: string; ref?: { url: string; text: string } };

const talks: Talk[] = [
  { year: 2026, venue: "Georgetown Law, Institute of International Economic Law, Washington DC", title: "Control and Ownership of Digital Assets under Private Commercial Law" },
  { year: 2026, venue: "Bank Policy Institute, Washington DC", title: "The Moneyness of Stablecoins", ref: { url: "/articles/moneyness-of-stablecoins", text: "The Moneyness of Stablecoins" } },
  { year: 2026, venue: "UNCITRAL Colloquium, New York City", title: "Control as a Method for Third-Party Effectiveness for Security Rights" },
  { year: 2026, venue: "Federal Reserve Bank of Dallas, Dallas", title: "The Law and Regulation of Stablecoins", ref: { url: "/articles/moneyness-of-stablecoins", text: "The Moneyness of Stablecoins" } },
  { year: 2026, venue: "Association of American Law Schools, New Orleans", title: "Bankrupt Crypto Organizations", ref: { url: "/articles/bankrupt-crypto-organizations", text: "Bankrupt Crypto Organizations" } },
  { year: 2026, venue: "Association of American Law Schools, New Orleans", title: "Regulating Centralized Stablecoins", ref: { url: "/essays/regulating-stablecoins", text: "Regulating Centralized Stablecoins" } },

  { year: 2025, venue: "Pacific Law Foundation, Arlington", title: "\u201CBundle of Sticks\u201D Has Become Inadequate for Modern Digital Assets and Should Be Refined", ref: { url: "/articles/digital-assets-property-question", text: "Digital Assets and the Property Question" } },
  { year: 2025, venue: "American Bar Association, Business Law Section, Toronto", title: "Decrypting Crypto: Valuation, Due Diligence, and Legal Risks for Lenders" },
  { year: 2025, venue: "Federal Reserve Bank of New York, New York City", title: "Crypto and the Property Question", ref: { url: "/articles/digital-assets-property-question", text: "Digital Assets and the Property Question" } },
  { year: 2025, venue: "UNCITRAL Colloquium, New York City", title: "Verified Carbon Credits as Collateral in Secured Transactions" },

  { year: 2024, venue: "VII Conference on International Coordination of Secured Transactions Reform", title: "Verified Carbon Credits: Private Law Regime and Use as Collateral" },
  { year: 2024, venue: "Practicing Law Institute, San Francisco", title: "NFTs in Commercial Transactions", ref: { url: "/essays/nfts-structured-finance", text: "The Intersection of NFTs and Structured Finance" } },
  { year: 2024, venue: "Harvard-Wharton Insolvency and Restructuring Conference, Boston", title: "DAOs in Financial Distress", ref: { url: "/essays/daos-financial-distress", text: "DAOs in Financial Distress" } },
  { year: 2024, venue: "University of Pennsylvania, Regulation & Governance Conference, Philadelphia", title: "Debt Tokens", ref: { url: "/articles/debt-tokens", text: "Debt Tokens" } },
  { year: 2024, venue: "BYU/UChicago, Winter Bankruptcy Conference, Park City", title: "Debt Tokens", ref: { url: "/articles/debt-tokens", text: "Debt Tokens" } },
  { year: 2024, venue: "American Bar Association, Business Law Section", title: "From Traditional to Digital: The Evolving Legal Landscape of Commercial Transactions" },
  { year: 2024, venue: "Office of the Comptroller of the Currency, Washington DC", title: "Tokenization" },
  { year: 2024, venue: "University of Chicago, Chicago", title: "Digital Assets and the 2022 UCC Amendments" },
  { year: 2024, venue: "Association of American Law Schools, Washington DC", title: "Debt Tokens", ref: { url: "/articles/debt-tokens", text: "Debt Tokens" } },

  { year: 2023, venue: "American Bar Association, Business Law Section", title: "Busting Myths About Digital Assets and Uncovering the True Technology Mechanics Impacting Your Clients and Practice" },
  { year: 2023, venue: "UNIDROIT, Rome", title: "The DAPL Principles and the Transfer of Digital Assets" },
  { year: 2023, venue: "TerraLex/ACC, New York", title: "2022 UCC Amendments and the Dawn of Controllable Electronic Records" },
  { year: 2023, venue: "American Bar Association, Business Law Section", title: "Introducing Article 12 of the Uniform Commercial Code" },
  { year: 2023, venue: "KCON, Texas A&M Law School, Fort Worth", title: "UCC Article 12: It Is All About Control" },
  { year: 2023, venue: "Association of American Law Schools, San Diego", title: "Digital Assets, Virtual Currencies, and UCC Reform" },

  { year: 2022, venue: "Federal Reserve Bank of New York, New York", title: "The Private Law of Stablecoins", ref: { url: "/articles/private-law-stablecoins", text: "The Private Law of Stablecoins" } },
  { year: 2022, venue: "Baruch College, New York City", title: "The Emerging Private Law Framework for Digital Assets" },
  { year: 2022, venue: "UNIDROIT, Rome", title: "Enforcement and Digital Assets: Rights of Secured Creditors" },
  { year: 2022, venue: "Brooklyn Law School, New York City", title: "Commercial Law Harmonization: Past as Prologue" },
  { year: 2022, venue: "American Bar Association, Business Law Section Spring Meeting, Atlanta", title: "UCC and Emerging Technologies" },

  { year: 2021, venue: "American College of Commercial Finance Lawyers", title: "UCC and Emerging Technologies" },
  { year: 2021, venue: "University of Vienna, Vienna", title: "ULC/ALI Project on Digital Assets: Comparative Observations" },
  { year: 2020, venue: "UNIDROIT, Rome", title: "Model Law on Warehouse Receipts: Contractual Issues" },
  { year: 2019, venue: "UNIDROIT, Rome", title: "Distributed Ledger Technology and International Sales of Commodities" },
  { year: 2018, venue: "Universidad Carlos III Madrid, II Conference on International Coordination of Secured Transactions Law Reforms", title: "Distributed Ledger Technology as the Bridge Between General Secured Transactions Registers and Asset-Specific Registration Systems" },
  { year: 2017, venue: "American Bar Association, Business Law Section Meeting, New Orleans", title: "Making the Intangible Untouchable: Creating, Perfecting and Enforcing Security Interests in Intangibles in Cross-Border Transactions" },
  { year: 2017, venue: "UNCITRAL, Fourth International Colloquium on Secured Transactions, Vienna", title: "International Principles of Contract Law for IP Licences" }
];

const byYear = talks.reduce((acc, t) => {
  (acc[t.year] ||= []).push(t);
  return acc;
}, {} as Record<number, Talk[]>);
const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);
---

<Layout title="Invited Talks" description="Selected invited talks and conference presentations by Andrea Tosato on private law, commercial law, bankruptcy, digital assets, stablecoins, and verified carbon credits.">
  <div class="page-header">
    <div class="section-label">Engagements</div>
    <h1 class="page-title">Invited Talks</h1>
    <p class="page-lede">Selected talks and conference presentations.</p>
  </div>

  {years.map(year => (
    <section class="talks-year-group">
      <h2 class="subsection-label tabular">{year}</h2>
      <ol class="talks-list">
        {byYear[year].map(t => (
          <li class="talk">
            <div class="talk-year tabular">{year}</div>
            <div class="talk-body">
              <div class="talk-venue">{t.venue}</div>
              <div class="talk-title"><em>{t.title}</em></div>
              {t.ref && <a class="talk-ref" href={t.ref.url}>&rarr; {t.ref.text}</a>}
            </div>
          </li>
        ))}
      </ol>
    </section>
  ))}
</Layout>
