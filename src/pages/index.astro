---
import Layout from '../layouts/Layout.astro';

const recentArticles = [
  {
    title: "The Moneyness of Stablecoins",
    authors: ["Andrea Tosato", "Christopher K. Odinet", "Yesha Yadav"],
    journal: "Yale Law Journal",
    volume: "136",
    year: "forthcoming 2026",
    url: "/articles/moneyness-of-stablecoins"
  },
  {
    title: "Bankrupt Crypto Organizations",
    authors: ["Kara Bruce", "Christopher K. Odinet", "Andrea Tosato"],
    journal: "North Carolina Law Review",
    volume: "104",
    year: "forthcoming 2026",
    url: "/articles/bankrupt-crypto-organizations"
  },
  {
    title: "Digital Assets and the Property Question",
    authors: ["Christopher K. Odinet", "Andrea Tosato"],
    journal: "Florida Law Review",
    volume: "78",
    year: "forthcoming 2026",
    url: "/articles/digital-assets-property-question"
  }
];

const recentEssays = [
  {
    title: "Seeing the Intangible: Juliet Moringiello's Enduring Legacy in Property Law",
    authors: ["Andrea Tosato", "Christopher K. Odinet"],
    publication: "American Bankruptcy Law Review",
    year: "forthcoming 2026",
    url: "/essays/seeing-the-intangible"
  },
  {
    title: "Regulating Centralized Stablecoins: Comparing MiCAR and the GENIUS Act",
    authors: ["Andrea Tosato", "Christopher K. Odinet"],
    publication: "Notre Dame Law Review Reflection",
    year: "forthcoming 2026",
    url: "/essays/regulating-stablecoins"
  },
  {
    title: "Tokenized Real Estate: The Law and Tech of Digital Deeds",
    authors: ["Andrea Tosato", "Christopher K. Odinet"],
    publication: "Ohio State Law Journal Online",
    year: "forthcoming 2026",
    url: "/essays/tokenized-real-estate"
  }
];

const allNewsItems = [
  {
    date: "2026-04-15",
    iso: "2026-04-15",
    human: "15 April 2026",
    title: "Eighth Session of the UNIDROIT Working Group on Verified Carbon Credits",
    description: "Participating in the Eighth Session of the Working Group on the Legal Nature of Verified Carbon Credits at UNIDROIT in Rome.",
    url: "https://www.unidroit.org/work-in-progress/verified-carbon-credits/",
    external: true
  },
  {
    date: "2026-03-18",
    iso: "2026-03-18",
    human: "18 March 2026",
    title: "The Moneyness of Stablecoins forthcoming in the Yale Law Journal",
    description: "New article with Christopher K. Odinet and Yesha Yadav, developing an original framework for stablecoin moneyness.",
    url: "/articles/moneyness-of-stablecoins",
    external: false
  },
  {
    date: "2026-02-05",
    iso: "2026-02-05",
    human: "5 February 2026",
    title: "Bankrupt Crypto Organizations wins SEALS Submission of the Year Award",
    description: "The co-authored article, forthcoming in the North Carolina Law Review, has been selected as the 2026 Submission of the Year by the Southeastern Association of Law Schools.",
    url: "/articles/bankrupt-crypto-organizations",
    external: false
  },
  {
    date: "2025-10-01",
    iso: "2025-10-01",
    human: "1 October 2025",
    title: "Elected to the American Law Institute",
    description: "Elected to membership in the American Law Institute, one of the highest honours in the American legal profession.",
    url: "https://www.smu.edu/law/news-events/2025/professor-andrea-tosato-elected-to-ali-membership",
    external: true
  }
];
---

<Layout>
  <section class="hero">
    <img class="portrait" src="/profile.jpg" alt="Andrea Tosato, Professor of Law at SMU Dedman School of Law">
    <div class="hero-text">
      <h1>Andrea Tosato</h1>
      <div class="title-line">Professor of Law &nbsp;&middot;&nbsp; SMU Dedman School of Law</div>
      <p class="positioning">
        Private law, commercial law, and the legal architecture of modern intangible assets.
      </p>
      <div class="elsewhere">
        <span class="elsewhere-label">Elsewhere</span>
        <a href="https://www.smu.edu/law/faculty/profiles/tosato-andrea" target="_blank" rel="noopener">SMU</a><span class="sep">&middot;</span>
        <a href="https://papers.ssrn.com/sol3/cf_dev/AbsByAuth.cfm?per_id=1851659" target="_blank" rel="noopener">SSRN</a><span class="sep">&middot;</span>
        <a href="https://scholar.google.com/citations?user=gvFpxc4AAAAJ" target="_blank" rel="noopener">Google Scholar</a><span class="sep">&middot;</span>
        <a href="https://orcid.org/0000-0002-2607-2702" target="_blank" rel="noopener">ORCID</a><span class="sep">&middot;</span>
        <a href="https://www.linkedin.com/in/andrea-tosato-5a862067/" target="_blank" rel="noopener">LinkedIn</a><span class="sep">&middot;</span>
        <a href="https://x.com/Andrea_Tosato" target="_blank" rel="noopener">X</a><span class="sep">&middot;</span>
        <a href="/Andrea-Tosato-CV.pdf">Curriculum Vitae (PDF)</a>
      </div>
    </div>
  </section>

  <section class="section columned">
    <div class="section-label">News</div>
    <div class="section-body">
      <div class="news-list">
        {allNewsItems.map(item => (
          <article class="news-item">
            <time class="news-date tabular" datetime={item.iso}>{item.human}</time>
            <div class="news-body">
              <h3>
                <a href={item.url} target={item.external ? "_blank" : undefined} rel={item.external ? "noopener" : undefined}>{item.title}</a>
              </h3>
              <p>{item.description}</p>
            </div>
          </article>
        ))}
      </div>
      <a class="view-all" href="/news">All news</a>
    </div>
  </section>

  <section class="section columned">
    <div class="section-label">About</div>
    <div class="section-body">
      <div class="about-text">
        <p>A private law and commercial law scholar, examining how legal frameworks developed for tangible property adapt to assets that are intangible, programmable, and distributed. Current work addresses digital assets, stablecoins, and verified carbon credits, at the intersection of secured transactions and bankruptcy.</p>
        <p>Contributor to the 2022 Amendments to the Uniform Commercial Code, member of the UNIDROIT drafting committees on digital assets and verified carbon credits, co-reporter for the Uniform Law Commission Study Committee on a Commercial Law Framework for Voluntary Carbon Credits, and Associate Research Director of the Permanent Editorial Board for the UCC. Elected to the American Law Institute in 2025.</p>
      </div>
      <a class="view-all" href="/about-me">Read more</a>
    </div>
  </section>

  <section class="section columned">
    <div class="section-label">Writing</div>
    <div class="section-body">
      <div class="subsection-label">Articles &nbsp;&middot;&nbsp; recent</div>
      <ol class="bib">
        {recentArticles.map(a => (
          <li>
            {a.authors.join(', ')},
            <span class="title"><a href={a.url}><em>{a.title}</em></a></span>,
            {a.volume && <> {a.volume}</>} <span class="venue">{a.journal}</span>
            <span class="year">({a.year})</span>.
          </li>
        ))}
      </ol>

      <div class="subsection-label">Shorter writings</div>
      <ol class="bib">
        {recentEssays.map(e => (
          <li>
            {e.authors.join(', ')},
            <span class="title"><a href={e.url}><em>{e.title}</em></a></span>,
            <span class="venue">{e.publication}</span>
            <span class="year">({e.year})</span>.
          </li>
        ))}
      </ol>

      <a class="view-all" href="/articles">All writing</a>
    </div>
  </section>
</Layout>
