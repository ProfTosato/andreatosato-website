---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Law Reform" description="Andrea Tosato's law reform work includes the UCC, the Permanent Editorial Board, the Uniform Law Commission, UNIDROIT, and international commercial law projects involving digital assets and verified carbon credits.">
  <div class="page-header">
    <div class="section-label">Service</div>
    <h1 class="page-title">Law Reform</h1>
  </div>

  <div class="reform-list">

    <section class="reform-org">
      <h2 class="reform-org-name">Uniform Law Commission</h2>
      <ol class="reform-roles">
        <li class="reform-role">
          <div class="role-title">Study Committee on Commercial Law Framework for Voluntary Carbon Credits</div>
          <div class="role-meta"><span class="role-position">Co-Reporter</span><span class="role-dates tabular">September 2024 to present</span></div>
        </li>
        <li class="reform-role">
          <div class="role-title">Drafting Committee on the Virtual Currency Customer Protection Act</div>
          <div class="role-meta"><span class="role-position">Reporter</span><span class="role-dates tabular">June 2023 to April 2025</span></div>
        </li>
        <li class="reform-role">
          <div class="role-title">Permanent Editorial Board for the Uniform Commercial Code</div>
          <div class="role-meta"><span class="role-position">Associate Research Director</span><span class="role-dates tabular">March 2022 to present</span></div>
          <div class="role-note">Co-appointment with Professor Carla Reyes.</div>
        </li>
        <li class="reform-role">
          <div class="role-title">Enactment Committee for the 2022 Uniform Commercial Code Amendments</div>
          <div class="role-meta"><span class="role-position">Member</span><span class="role-dates tabular">August 2022 to present</span></div>
        </li>
        <li class="reform-role">
          <div class="role-title">UCC and Emerging Technologies Committee (Joint Committee with the American Law Institute)</div>
          <div class="role-meta"><span class="role-position">Member</span><span class="role-dates tabular">June 2019 to July 2022</span></div>
        </li>
      </ol>
    </section>

    <section class="reform-org">
      <h2 class="reform-org-name">UNIDROIT</h2>
      <ol class="reform-roles">
        <li class="reform-role">
          <div class="role-title">Drafting Committee for the Working Group developing the UNIDROIT Principles on Verified Carbon Credits</div>
          <div class="role-meta"><span class="role-position">Member</span><span class="role-dates tabular">June 2024 to present</span></div>
        </li>
        <li class="reform-role">
          <div class="role-title">Drafting Committee for the Working Group developing the UNIDROIT Principles on Digital Assets</div>
          <div class="role-meta"><span class="role-position">Member</span><span class="role-dates tabular">April 2022 to May 2023</span></div>
        </li>
        <li class="reform-role">
          <div class="role-title">Working Group developing the UNIDROIT Model Law on Warehouse Receipts</div>
          <div class="role-meta"><span class="role-position">Member</span><span class="role-dates tabular">April 2022 to May 2024</span></div>
        </li>
      </ol>
    </section>

    <section class="reform-org">
      <h2 class="reform-org-name">Italian Ministry of Foreign Affairs</h2>
      <ol class="reform-roles">
        <li class="reform-role">
          <div class="role-title">Advisor for International Commercial Law Affairs</div>
          <div class="role-meta"><span class="role-dates tabular">2008 to 2020</span></div>
        </li>
        <li class="reform-role">
          <div class="role-title">Delegate to the United Nations Commission on International Trade Law (UNCITRAL)</div>
          <div class="role-meta"><span class="role-position">Delegate</span><span class="role-dates tabular">2008 to 2017</span></div>
          <div class="role-note">Representing the Italian government in the negotiations for:</div>
          <ul class="role-subitems">
            <li>The UNCITRAL Model Law on Secured Transactions: Guide to Enactment (2017).</li>
            <li>The UNCITRAL Model Law on Secured Transactions (2016).</li>
            <li>The UNCITRAL Guide on the Implementation of a Security Rights Registry (2013).</li>
            <li>The UNCITRAL Legislative Guide on Secured Transactions Supplement on Security Rights in Intellectual Property (2010).</li>
          </ul>
        </li>
      </ol>
    </section>

  </div>
</Layout>
