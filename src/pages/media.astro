---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Media and Press">
  <style>
    .content {
      max-width: 850px;
      margin: 0 auto;
      padding: 2.5rem 2rem;
    }

    h1 {
      font-size: 2.5rem;
      font-weight: 300;
      margin-bottom: 1rem;
      letter-spacing: -0.02em;
      color: #000;
    }

    .intro {
      font-size: 1rem;
      line-height: 1.8;
      color: #444;
      margin-bottom: 2.5rem;
    }

    h2 {
      font-size: 1.3rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-top: 2.5rem;
      margin-bottom: 1.5rem;
      color: #000;
    }

    h2:first-of-type {
      margin-top: 0;
    }

    .media-item {
      margin-bottom: 1.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid #f0f0f0;
      line-height: 1.7;
    }

    .media-item:last-of-type {
      border-bottom: none;
    }

    .media-item a {
      color: #000;
      text-decoration: none;
      transition: opacity 0.2s;
      display: block;
    }

    .media-item a:hover {
      opacity: 0.5;
      text-decoration: underline;
    }

    .article-ref {
      display: inline-block;
      font-size: 0.85rem;
      color: #666;
      margin-left: 0.5rem;
    }

    .article-ref:hover {
      color: #000;
    }

    @media (max-width: 768px) {
      .content {
        padding: 2rem 1.5rem;
      }

      h1 {
        font-size: 2rem;
      }

      h2 {
        font-size: 1.1rem;
      }
    }
  </style>

  <div class="content">
    <h1>Media and Press</h1>

    <p class="intro">
      For media inquiries, please contact Professor Tosato via his <a href="https://www.smu.edu/law/faculty/profiles/tosato-andrea" target="_blank" rel="noopener">SMU faculty page</a>.
    </p>

    <h2>Podcasts and Panels</h2>

    <div class="media-item">
      <a href="https://www.americanbar.org/groups/business_law/resources/audio-collection/2025/decrypting-crypto-valuation-due-diligence-and-legal-risks-for-lenders/" target="_blank" rel="noopener">
        ABA Business Law Section: Decrypting Crypto: Valuation, Due Diligence, and Legal Risks for Lenders (September 2025)
      </a>
    </div>

    <div class="media-item">
      <a href="https://www.youtube.com/watch?v=4X904wo-56w&ab_channel=Block%26Order" target="_blank" rel="noopener">
        Block & Order Podcast #36: Bankrupt Crypto Organizations feat. Kara Bruce, Chris Odinet, & Andrea Tosato (June 2025)
      </a>
      <a href="/articles/bankrupt-crypto-organizations" class="article-ref">→ Bankrupt Crypto Organizations</a>
    </div>

    <div class="media-item">
      <a href="https://learningcenter.americanbar.org/courses/79430" target="_blank" rel="noopener">
        ABA Business Law Section: From Traditional to Digital: The Evolving Legal Landscape of Commercial Transactions (April 2024)
      </a>
    </div>

    <div class="media-item">
      <a href="https://www.americanbar.org/groups/business_law/resources/audio-collection/busting-myths-about-digital-assets/" target="_blank" rel="noopener">
        ABA Business Law Section: Busting Myths About Digital Assets and Uncovering the True Technology Mechanics Impacting Your Clients and Practice (November 2023)
      </a>
    </div>

    <div class="media-item">
      <a href="https://www.americanbar.org/groups/business_law/resources/on-demand/introducing-article-12-of-uniform-commercial-code/" target="_blank" rel="noopener">
        ABA Business Law Section: Introducing Article 12 of the Uniform Commercial Code (April 2023)
      </a>
    </div>

    <h2>Press Coverage</h2>

    <div class="media-item">
      <a href="https://www.coindesk.com/policy/2023/05/17/floridas-desantis-waging-toothless-campaign-against-digital-dollars-lawyers-say/" target="_blank" rel="noopener">
        Coindesk: Florida's DeSantis Waging Toothless Campaign Against Digital Dollars, Lawyers Say (May 2023)
      </a>
    </div>

    <div class="media-item">
      <a href="https://www.barrons.com/articles/crypto-commercial-laws-definition-of-money-5fbd8fe4" target="_blank" rel="noopener">
        Barron's: Crypto's Future Is at Stake in a Dispute Over Commercial Law's Definition of Money (April 2023)
      </a>
    </div>
  </div>
</Layout>
