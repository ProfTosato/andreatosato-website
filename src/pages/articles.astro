        {a.volume && <> {a.volume}</>} <span class="venue">{a.venue}</span>
        <span class="year">({a.year})</span>.
        {a.notes.length > 0 && (
          <div class="notes">{a.notes.join(' ')}</div>
        )}
      </li>
    ))}
  </ol>
</Layout>
