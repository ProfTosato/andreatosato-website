---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Teaching" description="Andrea Tosato teaches Contracts, Torts, Secured Transactions, Bankruptcy Law, International Business Transactions, and Blockchain and the Law at SMU Dedman School of Law.">
  <div class="page-header">
    <div class="section-label">Teaching</div>
    <h1 class="page-title">Teaching</h1>
  </div>

  <div class="courses">
    <section class="course-group">
      <h2 class="course-heading">Foundation courses</h2>
      <ul class="course-list">
        <li>Contract Law</li>
        <li>Tort Law</li>
      </ul>
    </section>

    <section class="course-group">
      <h2 class="course-heading">Elective courses</h2>
      <ul class="course-list">
        <li>Secured Transactions</li>
        <li>Bankruptcy Law</li>
        <li>International Business Transactions</li>
        <li>Blockchain and the Law</li>
      </ul>
    </section>
  </div>
</Layout>
